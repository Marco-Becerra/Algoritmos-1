Algoritmo Calcular_Velocidad
	// definir Variables
	Definir velocidad, tiempo, distancia Como Real;
	// entrada de Datos
	Escribir 'Ingrese la distancia recorrida: ';
	Leer distancia;
	Escribir 'ingrese el tiempo trasncurrido: ';
	Leer tiempo;
	// Proceso
	// conociendo v=d/t
	velocidad <- distancia/tiempo;
	// salida de Datos
	Escribir 'la vlocidad de viajes es: ', velocidad, 'm/s';
FinAlgoritmo
