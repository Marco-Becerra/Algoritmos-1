Algoritmo Hallar_Area_Triangulo
	// Marco Becerra
	// Definir variables
	Definir base, altura como entero;
	Definir area como real;
	// Entrada de Datos
	Escribir "Ingrese la base del triangulo: ";
	Leer base;
	Escribir "Ingrese la altura del tirangulo: ";
	Leer altura;
	// proceso
	area <- (base * altura) / 2;
	// Salida de datos
	Escribir "El area del triangulo es " , area, " m2";
FinAlgoritmo
